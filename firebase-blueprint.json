{
  "entities": {
    "Room": {
      "title": "Watch Party Room",
      "description": "A room for synchronized movie watching",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "movieSlug": { "type": "string" },
        "movieName": { "type": "string" },
        "activeEpisodeSlug": { "type": "string" },
        "activeEpisodeName": { "type": "string" },
        "playbackState": { "type": "string", "enum": ["playing", "paused"] },
        "currentTime": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "hostId": { "type": "string" },
        "users": { "type": "object" }
      },
      "required": ["name", "movieSlug", "hostId"]
    },
    "Chat": {
      "title": "Chat Message",
      "description": "A message sent in a watch party room",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "timestamp"]
    },
    "Short": {
      "title": "Short Video",
      "description": "A short video clip uploaded or clipped from a movie",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["clip", "upload"] },
        "title": { "type": "string" },
        "videoUrl": { "type": "string" },
        "movieSlug": { "type": "string" },
        "movieName": { "type": "string" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "likesCount": { "type": "number" },
        "createdAt": { "type": "number", "description": "Timestamp in milliseconds" }
      },
      "required": ["type", "title", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "rooms": {
      "schema": "Room",
      "description": "Top-level collection for watch party rooms"
    },
    "rooms/{roomId}/chat": {
      "schema": "Chat",
      "description": "Sub-collection for messages in a room"
    },
    "shorts": {
      "schema": "Short",
      "description": "Top-level collection for short videos"
    }
  }
}
