{
  "version": 2,
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "/api/robots"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/sitemap-static.xml",
      "destination": "/api/sitemap?type=static"
    },
    {
      "source": "/sitemap-movies-:page.xml",
      "destination": "/api/sitemap?type=movies&page=:page"
    },
    {
      "source": "/api/ophim-movies/(.*)",
      "destination": "/api/ophim-proxy?path=$1"
    },
    {
      "source": "/api/cosplay/(.*)",
      "destination": "/api/cosplay-proxy?path=$1"
    },
    {
      "source": "/api/topxx-movies/(.*)",
      "destination": "/api/topxx-proxy?path=$1"
    },
    {
      "source": "/api/xxvn-movies/(.*)",
      "destination": "/api/xxvn-proxy?path=$1"
    },
    {
      "source": "/api/nguonc-movies/(.*)",
      "destination": "/api/nguonc-proxy?path=$1"
    },
    {
      "source": "/api/vsphim-movies/(.*)",
      "destination": "/api/vsphim-proxy?path=$1"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "https://topxx.vip/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
